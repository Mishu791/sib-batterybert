cat > .gitignore << 'EOF'
# Large data directories
data/pdfs_raw/
data/processed/
data/raw_dois/
data/splits/


# Annotation large files
annotation/preannotated_1000.json

# Virtual environment
venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# Jupyter checkpoints
.ipynb_checkpoints/

# OS
.DS_Store

# Large model files
*.bin
*.pt
*.safetensors
models/checkpoints/
models/published/
EOF